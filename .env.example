# ============================================
# InsightScribe Backend Environment Variables
# ============================================

# Environment
DJANGO_ENV=prod
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=.up.railway.app

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend origin(s)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Authentication / API throttles
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
THROTTLE_RATE_ANON=20/min
THROTTLE_RATE_USER=100/min
THROTTLE_RATE_AUTH_BURST=5/min
THROTTLE_RATE_AUTH_SUSTAINED=30/hour

# Upload constraints
MAX_UPLOAD_SIZE_MB=200

# OpenAI
OPENAI_API_KEY=

# Optional: S3-compatible storage (Supabase Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=interview-uploads
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# Optional: Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: Observability / logging
LOG_LEVEL=INFO
SENTRY_DSN=
ENABLE_FILE_LOGGING=False
FILE_LOG_PATH=/tmp/insightscribe.log
